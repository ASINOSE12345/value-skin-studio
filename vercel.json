{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "admin/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/admin/admin.js", "dest": "/admin/admin.js" },
    { "src": "/admin/admin.css", "dest": "/admin/admin.css" },
    { "src": "/admin/(.*\\.(js|css|png|jpg|svg|ico))", "dest": "/admin/$1" },
    { "src": "/admin/?", "dest": "/admin/index.html" },
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "^/$", "dest": "/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
