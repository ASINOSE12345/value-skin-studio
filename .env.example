# ============================================
# VALUE SKIN STUDIO - CONFIGURACION DE ENTORNO
# ============================================
# Copiar este archivo a .env y completar los valores

# ============================================
# SERVIDOR
# ============================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5500

# ============================================
# SUPABASE (Base de datos PostgreSQL)
# ============================================
# Obtener de: https://supabase.com/dashboard/project/[tu-proyecto]/settings/api
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ============================================
# JWT (Autenticacion)
# ============================================
# Generar una clave segura: openssl rand -base64 64
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# ============================================
# CLOUDINARY (Almacenamiento de imagenes)
# ============================================
# Obtener de: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ============================================
# EMAIL (SMTP)
# ============================================
# Configuracion para envio de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-password-de-aplicacion

# Email para notificaciones administrativas
NOTIFICATION_EMAIL=info@valueskinstudio.com
EMAIL_FROM_NAME=Value Skin Studio

# ============================================
# CONTACTO (Informacion del negocio)
# ============================================
CONTACT_PHONE=+54 9 3764 106773
CONTACT_WHATSAPP=5493764106773
CONTACT_EMAIL=contacto@valueskinstudio.com

# ============================================
# WHATSAPP BUSINESS API
# ============================================
# Obtener credenciales de: https://developers.facebook.com/apps
# 1. Crear App > Business > WhatsApp
# 2. Obtener Phone Number ID y Access Token
WHATSAPP_PHONE_NUMBER_ID=tu-phone-number-id
WHATSAPP_ACCESS_TOKEN=tu-access-token-permanente
WHATSAPP_BUSINESS_ACCOUNT_ID=tu-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=vss-webhook-2024

# ============================================
# SEGURIDAD
# ============================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:5500

# ============================================
# DESARROLLO
# ============================================
# Habilitar logs detallados
DEBUG=true

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA commits el archivo .env con datos reales
# 2. En produccion, usa variables de entorno de la plataforma
# 3. Cambia JWT_SECRET en produccion
# 4. Usa passwords de aplicacion para Gmail SMTP
# 5. Ejecuta 'node api/seeds' para crear datos iniciales
